---
layout: page
---
<div class="post">
    <article>
        {% if page.profiles %}
            <div class="profiles-container">
            {% for profile in page.profiles %}
                
                {% if profile.separator %}
                <div class="institution-separator w-100 clearfix">
                    <h2 class="text-center separator-title">{{ profile.separator }}</h2>
                </div>
                {% continue %}
                {% endif %}

                {% if profile.category == 'external' %}
                    <div class="external-member-card">
                        <div class="external-card-inner">
                            {% if profile.image %}
                                <div class="external-img-box">
                                    {% assign profile_image_path = profile.image | prepend: 'assets/img/' %}
                                    <img src="{{ profile_image_path | relative_url }}" alt="{{ profile.name }}">
                                </div>
                            {% endif %}
                            <div class="external-info p-3 text-center">
                                <h5 class="mb-1 font-weight-bold">{{ profile.name }}</h5>
                                <span class="badge badge-light mb-2">{{ profile.role }}</span>
                                <p class="small text-muted mb-3">{{ profile.institution }}</p>
                                
                                <div class="external-links">
                                    {% if profile.email %}<a href="mailto:{{ profile.email }}"><i class="fa-solid fa-envelope"></i></a>{% endif %}
                                    {% if profile.social.linkedin %}<a href="https://linkedin.com/in/{{ profile.social.linkedin }}" target="_blank"><i class="fab fa-linkedin"></i></a>{% endif %}
                                    {% if profile.social.scholar %}<a href="https://scholar.google.com/citations?user={{ profile.social.scholar }}" target="_blank"><i class="fas fa-graduation-cap"></i></a>{% endif %}
                                </div>
                            </div>
                        </div>
                    </div>

                {% else %}
                    <div class="core-profile-block clearfix">
                        <div class="profile-header-divider"></div>
                        <div class="profile float-{% if profile.align == 'left' %}left{% else %}right{% endif %}">
                            {% if profile.image %}
                                <div class="profile-img-container">
                                    {% assign profile_image_path = profile.image | prepend: 'assets/img/' %}
                                    {% if profile.image_circular %}
                                        {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
                                    {% else %}
                                        {% assign profile_image_class = 'img-fluid z-depth-1 rounded-lg' %}
                                    {% endif %}
                                    {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px) 30vw, 95vw"{% endcapture %}
                                    {% include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=profile.image %}
                                    
                                    {% if profile.role %}
                                    <div class="role-badge">{{ profile.role }}</div>
                                    {% endif %}
                                </div>
                            {% endif %}

                            <div class="more-info shadow-sm">
                                {% if profile.email %}
                                    <div class="info-link"><i class="fa-solid fa-envelope"></i> <a href="mailto:{{ profile.email }}">{{ profile.email }}</a></div>
                                {% endif %}
                                {% if profile.email2 %}
                                    <div class="info-link"><i class="fa-solid fa-envelope"></i> <a href="mailto:{{ profile.email2 }}">{{ profile.email2 }}</a></div>
                                {% endif %}
                                {% if profile.website %}
                                    <div class="info-link"><i class="fa-solid fa-globe"></i> <a href="{{ profile.website }}" target="_blank">Website</a></div>
                                {% endif %}
                                {% if profile.social.linkedin %}
                                    <div class="info-link"><i class="fab fa-linkedin"></i> <a href="https://www.linkedin.com/in/{{ profile.social.linkedin }}" target="_blank">LinkedIn</a></div>
                                {% endif %}
                                {% if profile.social.scholar %}
                                    <div class="info-link"><i class="fas fa-graduation-cap"></i> <a href="https://scholar.google.com/citations?user={{ profile.social.scholar }}" target="_blank">Google Scholar</a></div>
                                {% endif %}
                                {% if profile.more_info %}
                                    <div class="more-info-details mt-2">{{ profile.more_info }}</div>
                                {% endif %}
                            </div>
                        </div>

                        <div class="bio-content">
                            {% if profile.content %}
                                {% capture profile_content %}{% include_relative {{ profile.content }} %}{% endcapture %}
                                {{ profile_content | markdownify }}
                            {% else %}
                                {{ content }}
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
            </div>
        {% endif %}
    </article>
</div>

<style>
    /* TYPOGRAPHY & SEPARATORS */
    .separator-title { font-weight: 800; text-transform: uppercase; letter-spacing: 2px; color: var(--global-theme-color); margin: 3rem 0; }
    .profile-header-divider { height: 1px; background: var(--global-divider-color); margin: 2rem 0; opacity: 0.5; }

    /* CORE MEMBER STYLE */
    .core-profile-block { margin-bottom: 4rem; }
    .profile-img-container { position: relative; margin-bottom: 1rem; }
    .rounded-lg { border-radius: 1rem !important; }
    
    .role-badge { 
        position: absolute; bottom: 10px; right: 10px; background: var(--global-theme-color);
        color: white; padding: 2px 10px; border-radius: 5px; font-size: 0.7rem; font-weight: bold;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }

    .more-info { background: var(--global-card-bg-color); border: 1px solid var(--global-divider-color); padding: 15px; border-radius: 10px; margin-top: 15px; }
    .info-link { font-size: 0.85rem; margin-bottom: 4px; display: flex; align-items: center; gap: 8px; }
    .info-link i { color: var(--global-theme-color); width: 14px; text-align: center; }
    .more-info-details { font-size: 0.75rem; line-height: 1.4; border-top: 1px solid var(--global-divider-color); pt: 10px; opacity: 0.8; }

    /* EXTERNAL MEMBER GRID */
    .profiles-container { display: flex; flex-wrap: wrap; gap: 20px; }
    .external-member-card { width: calc(33.33% - 14px); margin-bottom: 20px; }
    .external-card-inner { 
        background: var(--global-bg-color); border: 1px solid var(--global-divider-color); 
        border-radius: 15px; overflow: hidden; height: 100%; transition: transform 0.3s;
    }
    .external-card-inner:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
    .external-img-box { height: 180px; width: 100%; }
    .external-img-box img { width: 100%; height: 100%; object-fit: cover; }
    .external-links a { font-size: 1.1rem; margin: 0 8px; color: var(--global-text-color); opacity: 0.7; }
    .external-links a:hover { color: var(--global-theme-color); opacity: 1; }

    /* FLOATING OVERRIDES */
    .profile.float-right { margin-left: 2rem; width: 30%; min-width: 250px; }
    .profile.float-left { margin-right: 2rem; width: 30%; min-width: 250px; }
    .bio-content h2, .bio-content h3 { font-weight: 800; margin-top: 0; }

    @media (max-width: 768px) {
        .external-member-card { width: 100%; }
        .profile { float: none !important; width: 100% !important; margin: 0 0 20px 0 !important; }
    }
</style>